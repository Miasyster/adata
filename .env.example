# adata configuration

# Data storage directory (default: ~/.adata)
# ADATA_DIR=/path/to/data

# rqdatac credentials
RQDATAC_USERNAME=
RQDATAC_PASSWORD=

# tushare pro token (https://tushare.pro)
TUSHARE_TOKEN=

# PolarDB (required if using polardb provider)
POLARDB_HOST=
POLARDB_PASSWORD=
# POLARDB_PORT=3306
# POLARDB_USER=readonly
# POLARDB_DB=one_platform
